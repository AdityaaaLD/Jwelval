PORT=3001
NODE_ENV=development
DB_PATH=./data/jewel_val.db

# --- Google Vision OCR (choose one credential method) ---
# Method 1: file path to service account json
# GOOGLE_APPLICATION_CREDENTIALS=./server/secrets/google-vision-service-account.json

# Method 2: raw service account JSON string
# GOOGLE_VISION_CREDENTIALS_JSON={"type":"service_account",...}

# Method 3: base64-encoded service account JSON string
# GOOGLE_VISION_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwuLi59

# --- Production (Railway) ---
# NODE_ENV=production
# DB_PATH=/data/jewel_val.db
# PORT is set automatically by Railway

# --- Production (Render) ---
# NODE_ENV=production
# DB_PATH=/opt/render/project/src/server/data/jewel_val.db
# PORT is set automatically by Render
