# Google Vision OCR setup (choose exactly one method)

# Method 1 (recommended for local/dev): service account key file path
# GOOGLE_APPLICATION_CREDENTIALS=./server/secrets/google-vision-service-account.json

# Method 2 (for secret managers): full JSON in a single env variable
# GOOGLE_VISION_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id",...}

# Method 3 (for platforms that prefer encoded secrets): base64 JSON
# GOOGLE_VISION_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwuLi59
